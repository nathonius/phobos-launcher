@let state = viewService.appState();
<div class="grow overflow-hidden">
  @switch (state) {
    @case (AppViewState.Home) {
      <app-home />
    }
    @case (AppViewState.Settings) {
      <app-settings />
    }
    @case (AppViewState.Engines) {
      <app-engines />
    }
    @case (AppViewState.Bases) {
      <app-bases />
    }
  }
</div>
<div class="navbar justify-between bg-base-300">
  <div class="flex gap-2">
    <button
      class="btn tooltip"
      data-tip="Home"
      [ngClass]="state === AppViewState.Home ? 'btn-primary' : 'btn-ghost'"
      (click)="viewService.appState.set(AppViewState.Home)"
    >
      <svg lucideHouse></svg>
    </button>
    <button
      class="btn tooltip"
      data-tip="Settings"
      [ngClass]="state === AppViewState.Settings ? 'btn-primary' : 'btn-ghost'"
      (click)="viewService.appState.set(AppViewState.Settings)"
    >
      <svg lucideSettings></svg>
    </button>
    <button
      class="btn tooltip"
      data-tip="Engines"
      [ngClass]="state === AppViewState.Engines ? 'btn-primary' : 'btn-ghost'"
      (click)="viewService.appState.set(AppViewState.Engines)"
    >
      <svg lucideCog></svg>
    </button>
    <button
      class="btn tooltip"
      data-tip="Base WADs"
      [ngClass]="state === AppViewState.Bases ? 'btn-primary' : 'btn-ghost'"
      (click)="viewService.appState.set(AppViewState.Bases)"
    >
      <svg lucidePackage></svg>
    </button>
  </div>
  <div class="flex gap-2">
    @let unsavedChanges = navbarService.unsavedChanges();
    @let callbacks = navbarService.callbacks();
    @if (callbacks.reset) {
      <button
        type="button"
        class="btn"
        [ngClass]="{
          'btn-disabled': !unsavedChanges,
        }"
        (click)="callbacks.reset.cb()"
        [disabled]="!unsavedChanges"
      >
        <svg lucideRotateCcw></svg> {{ callbacks.reset.label }}
      </button>
    }
    @if (callbacks.delete) {
      <button
        type="button"
        class="btn btn-ghost"
        (click)="callbacks.delete.cb()"
      >
        <svg lucideTrash></svg> {{ callbacks.delete.label }}
      </button>
    }
    @if (callbacks.save) {
      @let saved = navbarService.saved();
      <button
        type="button"
        class="btn transition-colors"
        (click)="callbacks.save.cb()"
        [ngClass]="{ 'btn-primary': !saved, 'btn-success': saved }"
      >
        @if (saved) {
          <svg lucideCheck></svg>
        } @else {
          <svg lucideSave></svg>
        }
        {{ callbacks.save.label }}
      </button>
    }
    @if (callbacks.edit) {
      <button
        type="button"
        class="btn btn-primary"
        (click)="callbacks.edit.cb()"
      >
        <svg lucideWrench></svg> {{ callbacks.edit.label }}
      </button>
    }
    @if (callbacks.new) {
      <button
        type="button"
        class="btn btn-secondary"
        (click)="callbacks.new.cb()"
      >
        <svg lucidePlus></svg> {{ callbacks.new.label }}
      </button>
    }
    @if (callbacks.launch) {
      <button
        type="button"
        class="btn btn-secondary"
        (click)="callbacks.launch.cb()"
      >
        <svg lucideRocket></svg> {{ callbacks.launch.label }}
      </button>
    }
  </div>
</div>
